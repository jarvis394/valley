{
  "name": "valley",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "author": "jarvis394",
  "license": "MIT",
  "scripts": {
    "dev": "turbo dev --filter !storybook",
    "storybook": "turbo dev --filter storybook",
    "docker:dev": "docker compose -f docker-compose.dev.yml up",
    "build": "NODE_ENV=production turbo build",
    "db:seed": "pnpm workspace @valley/db db:seed",
    "db:studio": "pnpm workspace @valley/db db:studio",
    "db:migrate": "pnpm workspace @valley/db db:migrate",
    "db:migrate:reset": "pnpm workspace @valley/db db:migrate:reset",
    "upload:ace": "node ./apps/upload/ace",
    "prepare": "husky",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "preinstall": "pnpm add -g node-gyp"
  },
  "devDependencies": {
    "@caxy/dotenv-updater": "^1.0.9",
    "@valley/eslint-config": "workspace:*",
    "@valley/typescript-config": "workspace:*",
    "lint-staged": "^15.2.9",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.14.3+sha512.c0f53ee99477ed969b82b289ad011a5d16bf1623c957e7f29eabe8d0c00b574c29b8c7f54f6c67ee710c73f285c8154d07ce44b46fe2c0eeb476a90441bac371",
  "dependencies": {
    "husky": "^9.1.4",
    "sharp": "^0.33.5"
  },
  "dotenvUpdater": {
    "envFile": ".env",
    "distFile": ".env.template",
    "checkExtraVars": true
  },
  "overrides": {
    "strtok3": "8.0.1"
  },
  "resolutions": {
    "strtok3": "8.0.1"
  },
  "pnpm": {
    "overrides": {
      "strtok3": "8.0.1"
    }
  }
}
